<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Sports Store</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      margin: 0;
      background: #f4f4f4;
    }

    header {
      background: #111;
      color: white;
      padding: 15px;
      text-align: center;
      font-size: 24px;
    }

    nav {
      display: flex;
      justify-content: space-between;
      background: #222;
      padding: 10px 20px;
      color: white;
    }

    .cart {
      cursor: pointer;
    }

    .container {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      padding: 20px;
    }

    .card {
      background: white;
      width: 250px;
      margin: 15px;
      border-radius: 10px;
      box-shadow: 0 4px 8px rgba(0,0,0,0.2);
      overflow: hidden;
      text-align: center;
    }

    .card img {
      width: 100%;
      height: 180px;
      object-fit: cover;
    }

    .card h3 {
      margin: 10px 0;
    }

    .card p {
      color: green;
      font-weight: bold;
    }

    .card button {
      background: #28a745;
      border: none;
      color: white;
      padding: 10px;
      margin: 10px;
      cursor: pointer;
      border-radius: 5px;
    }

    .card button:hover {
      background: #218838;
    }

    #cartBox {
      position: fixed;
      right: 10px;
      top: 70px;
      width: 250px;
      background: white;
      border: 1px solid #ccc;
      padding: 10px;
      display: none;
      box-shadow: 0 4px 8px rgba(0,0,0,0.3);
    }

    #cartBox h4 {
      margin-top: 0;
    }

    footer {
      background: #111;
      color: white;
      text-align: center;
      padding: 10px;
      margin-top: 20px;
    }
  </style>
</head>
<body>

<header>🏆 Sports Store</header>

<nav>
  <div>Home | Shop | Contact</div>
  <div class="cart" onclick="toggleCart()">🛒 Cart (<span id="count">0</span>)</div>
</nav>

<div id="cartBox">
  <h4>Your Cart</h4>
  <ul id="cartItems"></ul>
</div>

<div class="container">

  <div class="card">
    <img src="https://via.placeholder.com/250x180?text=Football">
    <h3>Football</h3>
    <p>₹799</p>
    <button onclick="addToCart('Football')">Add to Cart</button>
  </div>

  <div class="card">
    <img src="https://via.placeholder.com/250x180?text=Cricket+Bat">
    <h3>Cricket Bat</h3>
    <p>₹1499</p>
    <button onclick="addToCart('Cricket Bat')">Add to Cart</button>
  </div>

  <div class="card">
    <img src="https://via.placeholder.com/250x180?text=Basketball">
    <h3>Basketball</h3>
    <p>₹999</p>
    <button onclick="addToCart('Basketball')">Add to Cart</button>
  </div>

  <div class="card">
    <img src="https://via.placeholder.com/250x180?text=Tennis+Racket">
    <h3>Tennis Racket</h3>
    <p>₹1999</p>
    <button onclick="addToCart('Tennis Racket')">Add to Cart</button>
  </div>

</div>

<footer>© 2026 Sports Store</footer>

<script>
  let cart = [];

  function addToCart(item) {
    cart.push(item);
    document.getElementById("count").innerText = cart.length;

    let li = document.createElement("li");
    li.innerText = item;
    document.getElementById("cartItems").appendChild(li);
  }

  function toggleCart() {
    let box = document.getElementById("cartBox");
    box.style.display = box.style.display === "none" ? "block" : "none";
  }
</script>

</body>
</html>
